    <script>
        // Initialize Lenis
        const lenis = new Lenis({
          duration: 1.2,      // How long the scroll takes (higher = slower/smoother)
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Acceleration/Deceleration curve
          wheelMultiplier: 1, // Sensitivity for mouse wheel
          smoothWheel: true
        });

        // Use requestAnimationFrame to force smooth updates
        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);

        //Connect navbar links so they use this same smooth engine
        document.querySelectorAll('.fixed-side-navbar a').forEach(anchor => {
          anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const target = document.querySelector(anchor.getAttribute('href'));
            if (target) {
              lenis.scrollTo(target);
            }
          });
        });
    </script>
    <script type="text/javascript">
        (function () {

            $(function () {
                var $accordion, $wideScreen;
                $accordion = $('#accordion').children('li');
                $wideScreen = $(window).width() > 767;
                if ($wideScreen) {
                    $accordion.on('mouseenter click', function (e) {
                        var $this;
                        e.stopPropagation();
                        $this = $(this);
                        if ($this.hasClass('out')) {
                            $this.addClass('out');
                        } else {
                            $this.addClass('out');
                            $this.siblings().removeClass('out');
                        }
                    });
                } else {
                    $accordion.on('touchstart touchend', function (e) {
                        var $this;
                        e.stopPropagation();
                        $this = $(this);
                        if ($this.hasClass('out')) {
                            $this.addClass('out');
                        } else {
                            $this.addClass('out');
                            $this.siblings().removeClass('out');
                        }
                    });
                }
            });
            $(function () {
                var $container, $menu, $menubtn, $navbar;
                $menubtn = $('#hb');
                        $navbar = $('.navbar');
                $menu = $('.navigation');
                $container = $('.site-inner');
                $menubtn.on('click', function (e) {
                    if ($menubtn.hasClass('active')) {
                        $menubtn.removeClass('active');
                        $menu.removeClass('slide-right');
                        $container.removeClass('slide-right');
                                        $navbar.removeClass('slide-right');
                    } else {
                        $menubtn.addClass('active');
                        $menu.addClass('slide-right');
                        $container.addClass('slide-right');
                                        $navbar.addClass('slide-right');
                    }
                });
            });
        }.call(this));

        </script>

